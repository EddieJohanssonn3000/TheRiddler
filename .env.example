# Example .env for local development
# Copy this file to `.env` when using `vercel dev` or other env-aware tools.
# Keep secrets out of git.

VITE_CENTRALBANK_API_URL=https://api.loopland.se
VITE_CENTRALBANK_API_KEY=your-centralbank-api-key
VITE_USE_MOCK_BANK=false

# Put your own local answer JSON here if you need it for local validation.
# Do not commit real answers to git.
RIDDLES_ANSWERS_JSON={"7":"<answer>","8":"<answer>","9":"<answer>"}
